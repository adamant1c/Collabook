# ========================================
# Security Configuration
# ========================================
# REQUIRED: Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-generate-with-openssl

# Environment (development or production)
ENVIRONMENT=development

# ========================================
# LLM Configuration (Choose ONE option)
# ========================================

# LLM Provider (ollama or gemini or groq or openai)
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
# GROQ_API_KEY=your-groq-api-key
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key

# Content Moderation
CONTENT_FILTER_LEVEL=moderate  # strict, moderate, or relaxed
LOG_VIOLATIONS=true

# Language
LANGUAGE=en  # en or it

# ========================================
# Database Configuration
# ========================================
# PRODUCTION: change all values below!
POSTGRES_USER=postgres
POSTGRES_DB=collabook
DB_PASSWORD=postgres       # Change in production!
DATABASE_URL=postgresql://${POSTGRES_USER}:${DB_PASSWORD}@db:5432/${POSTGRES_DB}

# ========================================
# Redis Configuration
# ========================================
REDIS_PASSWORD=redis_dev_password  # Change in production!
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ========================================
# Backend Configuration
# ========================================
BACKEND_URL=http://backend:8000

# ========================================
# Email Configuration (SMTP)
# ========================================
# Leave blank in development (uses MailHog on localhost:1025)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SENDER=noreply@collabook.com

# ========================================
# Google OAuth (optional)
# ========================================
# Required only if you enable Google Sign-In via django-allauth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ========================================
# AdSense Configuration
# ========================================
# Set to True when site is approved by Google AdSense
ADSENSE_ENABLED=False
